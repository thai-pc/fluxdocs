# --- Go ---
*.exe
*.exe*.dll
*.so
*.dylib
*.test
*.out
/bin/
/dist/
vendor/
go.work.sum

# WASM build artifacts
*.wasm
wasm_exec.js

# --- Node / JS wrappers ---
node_modules/
.pnpm-store/
packages/**/dist/
packages/**/build/
apps/**/dist/
apps/**/.vite/
