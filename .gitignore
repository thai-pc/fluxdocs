testing/**/*.actual.png
testing/**/output/

# --- Secrets & env ---
.env
.env.*
!.env.example
*.pem
*.key
*_rsa
credentials.json
service-account*.json

# Do NOT commit real PDFs with PII into the corpus.
# Synthetic / anonymized fixtures are tracked explicitly.

# --- Editor / OS ---
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
